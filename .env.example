──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────# ══════════════════════════════════════════════
# CHEFBOT - Arquivo de Configuração de Ambiente
# Copie este arquivo: cp .env.example .env
# Preencha os valores antes de iniciar
# ══════════════════════════════════════════════

# ──────────────────────────────────────────────
# SERVIDOR
# ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────
# IA - GROQ (GRATUITO)
# Obtenha sua chave em: https://console.groq.com
# Crie conta > API Keys > Create API Key
# ──────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelos disponíveis (todos gratuitos):
#   llama-3.3-70b-versatile  -> Melhor qualidade (recomendado)
#   llama-3.1-8b-instant     -> Mais rápido, menor custo
#   mixtral-8x7b-32768       -> Bom equilíbrio custo/qualidade
#   gemma2-9b-it             -> Alternativa leve
AI_MODEL=llama-3.3-70b-versatile

# Parâmetros do modelo (opcionais)
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=600

# ──────────────────────────────────────────────
# EVOLUTION API - WHATSAPP
# Instale via Docker:
#   docker run -d -p 8080:8080 \
#     -e AUTHENTICATION_API_KEY=minha-chave-secreta \
#     atendai/evolution-api:latest
#
# Acesse: http://localhost:8080
# Crie instância e escaneie QR Code com WhatsApp
# ──────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=minha-chave-secreta
EVOLUTION_INSTANCE=chefbot

# ──────────────────────────────────────────────
# BANCO DE DADOS
# SQLite local — não requer configuração extra
# O arquivo será criado automaticamente em:
#   backend/chefbot.db
# ──────────────────────────────────────────────
# DB_PATH=./chefbot.db   (opcional, padrão acima)
